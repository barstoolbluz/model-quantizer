#!/usr/bin/env bash
# quantize-fp8.sh — Convert a model to FP8 using torchao.
#
# FP8 (E4M3) is natively supported on Blackwell (SM120) and Hopper (SM90).
# This produces a static FP8 checkpoint that vLLM can load directly.
#
# Usage:
#   quantize-fp8.sh <model-id>
#
# Examples:
#   quantize-fp8.sh Qwen/Qwen3-8B
#   quantize-fp8.sh meta-llama/Llama-3.1-8B-Instruct
#
# Note: For many models, vLLM can do FP8 on-the-fly at load time with
# --quantization fp8, which avoids needing a separate checkpoint.
# Use this script when you want a pre-computed FP8 checkpoint for
# faster startup or to save disk space.

set -euo pipefail

MODEL_ID="${1:?Usage: quantize-fp8.sh <model-id>}"

CACHE_DIR="${MODEL_CACHE_DIR:-/home/daedalus/dev/vllm-runtime/models}"
OUTPUT_DIR="${QUANTIZED_OUTPUT_DIR:-$CACHE_DIR}"

OUTPUT_MODEL_ID="${MODEL_ID}-FP8"
OUTPUT_PATH="$OUTPUT_DIR/hub/models--$(echo "$OUTPUT_MODEL_ID" | tr "/" "--")/snapshots/main"

echo "=== FP8 Quantization ==="
echo "  Source:     $MODEL_ID"
echo "  Output:     $OUTPUT_MODEL_ID"
echo "  Format:     FP8 E4M3 (native Blackwell/Hopper)"
echo "  Cache:      $CACHE_DIR"
echo "  Output dir: $OUTPUT_PATH"
echo ""

if [ -d "$OUTPUT_PATH" ] && [ -f "$OUTPUT_PATH/config.json" ]; then
    echo "Output already exists at $OUTPUT_PATH"
    echo "Delete it first if you want to re-quantize."
    exit 0
fi

mkdir -p "$OUTPUT_PATH"

HF_CACHE="$CACHE_DIR/hub/models--$(echo "$MODEL_ID" | tr "/" "--")"
if [ ! -d "$HF_CACHE" ]; then
    echo "ERROR: Source model not found in cache: $HF_CACHE"
    echo "  Download it first with the inferencing-model-downloader environment."
    exit 1
fi

exec python3 -c "
import torch
import os
from transformers import AutoModelForCausalLM, AutoTokenizer
from torchao.quantization import quantize_, float8_weight_only

model_id = '$MODEL_ID'
output_path = '$OUTPUT_PATH'
cache_dir = '$CACHE_DIR'

os.environ['HF_HOME'] = cache_dir

print(f'Loading tokenizer for {model_id}...')
tokenizer = AutoTokenizer.from_pretrained(model_id, trust_remote_code=True)

print(f'Loading model {model_id} in BF16...')
model = AutoModelForCausalLM.from_pretrained(
    model_id,
    torch_dtype=torch.bfloat16,
    device_map='auto',
    trust_remote_code=True,
)

print('Quantizing weights to FP8 E4M3...')
quantize_(model, float8_weight_only())

print(f'Saving to {output_path}...')
model.save_pretrained(output_path, safe_serialization=True)
tokenizer.save_pretrained(output_path)

# Write refs/main for HF cache compatibility
refs_dir = os.path.dirname(os.path.dirname(output_path)) + '/refs'
os.makedirs(refs_dir, exist_ok=True)
with open(os.path.join(refs_dir, 'main'), 'w') as f:
    f.write('main')

print('Done.')
print(f'  Model saved to: {output_path}')

source_cache = f'{cache_dir}/hub/models--{model_id.replace(\"/\", \"--\")}'
source_size = sum(
    os.path.getsize(os.path.join(dp, f))
    for dp, dn, filenames in os.walk(source_cache)
    for f in filenames
) / (1024**3)
output_size = sum(
    os.path.getsize(os.path.join(dp, f))
    for dp, dn, filenames in os.walk(output_path)
    for f in filenames
) / (1024**3)
print(f'  Source size: {source_size:.1f} GB')
print(f'  Output size: {output_size:.1f} GB')
print(f'  Compression: {source_size/output_size:.1f}x')
"
